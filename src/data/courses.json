{
  "courses": [
    {
      "id": "ai-engineer",
      "title": "AI Engineering",
      "description": "Learn how to build, deploy, scale, and operate production-grade AI systems as a Forward Deployed AI Engineer.",
      "icon": "Brain",
      "color": "from-blue-500 to-cyan-500",
      "modules": [

        {
          "id": "ml-basics",
          "title": "Machine Learning Basics",
          "description": "Supervised, unsupervised, and applied ML foundations.",
          "lessons": [
            {
              "id": "supervised-learning",
              "title": "Supervised Learning Fundamentals",
              "type": "concept",
              "duration": "30 min",
              "description": "Regression, classification, and evaluation metrics.",
              "content": {
                "topics": [
                  "Linear regression",
                  "Logistic regression",
                  "Decision trees",
                  "Bias vs variance",
                  "Evaluation metrics (Precision, Recall, F1)"
                ]
              }
            },
            {
              "id": "unsupervised-learning",
              "title": "Unsupervised Learning",
              "type": "concept",
              "duration": "25 min",
              "description": "Clustering and dimensionality reduction.",
              "content": {
                "topics": [
                  "K-means clustering",
                  "Hierarchical clustering",
                  "PCA",
                  "Anomaly detection"
                ]
              }
            },
            {
              "id": "model-evaluation",
              "title": "Model Evaluation & Overfitting",
              "type": "interactive",
              "duration": "20 min",
              "description": "Avoiding common ML mistakes.",
              "content": {
                "topics": [
                  "Cross validation",
                  "Train/validation/test splits",
                  "Overfitting vs underfitting",
                  "Data leakage"
                ]
              }
            }
          ]
        },

        {
          "id": "deep-learning",
          "title": "Deep Learning",
          "description": "Neural networks, backpropagation, CNNs, and transformers.",
          "lessons": [
            {
              "id": "neural-networks",
              "title": "Neural Network Foundations",
              "type": "video",
              "duration": "35 min",
              "description": "Understanding layers, activation functions, and training.",
              "content": {
                "topics": [
                  "Perceptron",
                  "Activation functions (ReLU, Sigmoid)",
                  "Backpropagation",
                  "Gradient descent"
                ]
              }
            },
            {
              "id": "transformers",
              "title": "Transformers & Modern AI",
              "type": "concept",
              "duration": "40 min",
              "description": "Self-attention and LLM architecture.",
              "content": {
                "topics": [
                  "Attention mechanism",
                  "Encoder vs decoder",
                  "Tokenization",
                  "Fine-tuning vs prompting"
                ]
              }
            }
          ]
        },

        {
          "id": "nlp",
          "title": "Natural Language Processing",
          "description": "Text processing, embeddings, and LLM integration.",
          "lessons": [
            {
              "id": "text-processing",
              "title": "Text Preprocessing & Tokenization",
              "type": "concept",
              "duration": "25 min",
              "description": "Cleaning and preparing text data.",
              "content": {
                "topics": [
                  "Tokenization",
                  "Stopwords",
                  "Stemming & Lemmatization",
                  "TF-IDF"
                ]
              }
            },
            {
              "id": "embeddings",
              "title": "Embeddings & Vector Databases",
              "type": "concept",
              "duration": "35 min",
              "description": "Understanding semantic search.",
              "content": {
                "topics": [
                  "Vector embeddings",
                  "Cosine similarity",
                  "Semantic search",
                  "RAG systems"
                ]
              }
            },
            {
              "id": "llm-integration",
              "title": "LLM Integration in Applications",
              "type": "project",
              "duration": "2 hours",
              "description": "Build an LLM-powered API endpoint."
            }
          ]
        },

        {
          "id": "computer-vision",
          "title": "Computer Vision",
          "description": "Image recognition, CNNs, and deployment.",
          "lessons": [
            {
              "id": "cnn-basics",
              "title": "Convolutional Neural Networks",
              "type": "concept",
              "duration": "30 min",
              "description": "Understanding feature extraction.",
              "content": {
                "topics": [
                  "Convolution layers",
                  "Pooling",
                  "Feature maps",
                  "Transfer learning"
                ]
              }
            },
            {
              "id": "vision-deployment",
              "title": "Deploying Vision Models",
              "type": "project",
              "duration": "3 hours",
              "description": "Serve a vision model via API."
            }
          ]
        },

        {
          "id": "multi-agent-systems",
          "title": "Multi-Agent Systems & LangGraph",
          "description": "Build production-grade AI orchestration systems.",
          "lessons": [
            {
              "id": "agent-architecture",
              "title": "Agent Architecture Patterns",
              "type": "concept",
              "duration": "30 min",
              "description": "Tool use, planning, and structured outputs.",
              "content": {
                "topics": [
                  "Tool calling",
                  "Structured outputs",
                  "Agent loops",
                  "Guardrails"
                ]
              }
            },
            {
              "id": "langgraph-basics",
              "title": "LangGraph Fundamentals",
              "type": "concept",
              "duration": "40 min",
              "description": "StateGraph, nodes, and edges.",
              "content": {
                "topics": [
                  "Typed state",
                  "Reducers",
                  "Fan-out/fan-in",
                  "Parallel execution"
                ]
              }
            },
            {
              "id": "dialectical-agents",
              "title": "Dialectical Multi-Agent Systems",
              "type": "project",
              "duration": "4 hours",
              "description": "Build a Prosecutor/Defense/Tech Lead debate system."
            }
          ]
        },

        {
          "id": "forensic-ai",
          "title": "Forensic & Enterprise AI Systems",
          "description": "Build secure, enterprise-ready AI tooling.",
          "lessons": [
            {
              "id": "git-forensics",
              "title": "Git History Analysis & Automation",
              "type": "concept",
              "duration": "30 min",
              "description": "Programmatic repository analysis.",
              "content": {
                "topics": [
                  "Secure cloning",
                  "Parsing git logs",
                  "Commit pattern analysis",
                  "Security risks"
                ]
              }
            },
            {
              "id": "ast-analysis",
              "title": "Static Code Analysis with AST",
              "type": "concept",
              "duration": "35 min",
              "description": "Parsing Python code programmatically."
            },
            {
              "id": "secure-tooling",
              "title": "Secure Tool Engineering",
              "type": "concept",
              "duration": "25 min",
              "description": "Sandboxing, subprocess, and input validation."
            }
          ]
        },

        {
          "id": "mlops",
          "title": "MLOps & Deployment",
          "description": "Deploy, monitor, and scale machine learning systems.",
          "lessons": [
            {
              "id": "docker-ai",
              "title": "Dockerizing AI Systems",
              "type": "project",
              "duration": "2 hours",
              "description": "Containerize an AI service."
            },
            {
              "id": "cloud-deployment",
              "title": "Deploying on AWS",
              "type": "concept",
              "duration": "40 min",
              "description": "EC2, RDS, S3, IAM fundamentals."
            },
            {
              "id": "monitoring-ai",
              "title": "Monitoring & Observability",
              "type": "concept",
              "duration": "30 min",
              "description": "Logging, tracing, failure recovery."
            }
          ]
        },

        {
          "id": "capstone",
          "title": "Capstone: Autonomous AI Auditor",
          "description": "Build a full multi-agent AI system from scratch.",
          "lessons": [
            {
              "id": "capstone-design",
              "title": "System Design & Architecture Planning",
              "type": "project",
              "duration": "2 hours",
              "description": "Design your AI courtroom architecture."
            },
            {
              "id": "capstone-build",
              "title": "Build & Orchestrate Agents",
              "type": "project",
              "duration": "8 hours",
              "description": "Implement detective and judicial layers."
            },
            {
              "id": "capstone-deploy",
              "title": "Deploy & Present",
              "type": "project",
              "duration": "4 hours",
              "description": "Deploy and demo your system."
            }
          ]
        }

      ]
    }
  ]
}